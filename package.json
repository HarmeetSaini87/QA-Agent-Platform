{
  "name": "qa-agent-platform",
  "version": "1.0.0",
  "description": "Enterprise Playwright AI automation platform with MCP, Web UI, and multi-source test input",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "create-template": "tsx scripts/create-template.ts",
    "fetch-jira": "tsx scripts/fetch-jira-story.ts",
    "parse-attachments": "tsx scripts/parse-attachments.ts",
    "jira-to-plan": "tsx scripts/jira-to-plan.ts",
    "generate-plan": "tsx scripts/generate-plan.ts",
    "excel-to-plan": "tsx scripts/excel-to-plan.ts",
    "generate-report": "tsx scripts/generate-report.ts",
    "heal-run": "tsx scripts/heal-run.ts",
    "ui": "tsx src/ui/server.ts",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "lint": "eslint src/**/*.ts scripts/**/*.ts",
    "clean": "rimraf dist reports/*.html results/*.json test-plans/*.json"
  },
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express-session": "^1.18.2",
    "axios": "^1.6.7",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "connect-sqlite3": "^0.9.16",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-session": "^1.19.0",
    "form-data": "^4.0.0",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "open": "^10.1.0",
    "pdf-parse": "^1.1.1",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "ws": "^8.16.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.1",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/pdf-parse": "^1.1.4",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "rimraf": "^5.0.5",

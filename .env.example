# ============================================================
# qa-agent-platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to source control
# ============================================================

# ── Jira Integration ────────────────────────────────────────
# Your Jira Cloud base URL (no trailing slash)
JIRA_BASE_URL=https://pnmx.atlassian.net

# Your Jira account email
JIRA_EMAIL=your.email@company.com

# Jira API token — generate at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# ── Test credentials ────────────────────────────────────────
# Default login credentials used by the loggedIn fixture
APP_USERNAME=admin@company.com
APP_PASSWORD=YourPassword123

# ── Application ─────────────────────────────────────────────
# Port for the Web UI server
UI_PORT=3000

# Environment: local | staging | production
APP_ENV=local

# Base URL of the application under test
APP_BASE_URL=https://your-app-url.com

# ── Playwright ──────────────────────────────────────────────
# Browser mode — overridden automatically in ADO pipeline
HEADLESS=false

# Default timeout in milliseconds
DEFAULT_TIMEOUT=30000

# Screenshot on failure: always | only-on-failure | never
SCREENSHOT_MODE=only-on-failure

# ── Paths (relative to project root) ────────────────────────
REQUIREMENTS_DIR=./requirements
TEST_PLANS_DIR=./test-plans
RESULTS_DIR=./results
REPORTS_DIR=./reports

# ── Logging ─────────────────────────────────────────────────
# Log level: debug | info | warn | error
LOG_LEVEL=info
